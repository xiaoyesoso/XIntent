# LLM API Configuration
API_KEY=your-api-key-here
FLASH_LLM_MODEL=
PRO_LLM_MODEL=
EMBEDDING_MODEL=
RERANKER_MODEL=
BASE_URL=

# Optional: LLM client timeout and retry settings
# LLM_TIMEOUT=120      # Request timeout in seconds (default: 120)
# LLM_MAX_RETRIES=1    # Max retries on failure (default: 1, set 0 to disable)

# Fill in the model names according to your API provider.
# Example (SiliconFlow):
#   FLASH_LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash   # Layer 2: lightweight intent recognition
#   PRO_LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro        # Layer 3: deep reasoning intent recognition
#   EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
#   RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
#   BASE_URL=https://api.siliconflow.cn/v1